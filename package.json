    "hono": "^4.6.0",
    "ioredis": "^5.4.1",
    "nodemailer": "^6.9.0",
    "pino": "^9.5.0",
    "pino-pretty": "^13.0.0",
    "playwright": "^1.60.0",
    "sharp": "^0.34.5",
    "stripe": "^17.0.0",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.0",
    "@types/node": "^22.0.0",
    "@types/nodemailer": "^6.4.0",
    "drizzle-kit": "^0.28.0",
    "tsx": "^4.19.0",
